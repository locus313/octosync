# Copy to .env.e2e or .env before running `npm run test:e2e`.
#
# Use a throwaway repository. The harness creates and deletes a temporary
# branch named octosync-e2e-*, but the token must still have Contents read/write
# and Metadata read access to this repository.

OCTOSYNC_E2E_GITHUB_TOKEN=github_pat_your_throwaway_repo_token
OCTOSYNC_E2E_OWNER=your-github-owner-or-org
OCTOSYNC_E2E_REPO=your-throwaway-repo

# Optional. Defaults shown here.
# OCTOSYNC_E2E_BRANCH_PREFIX=octosync-e2e
# OCTOSYNC_E2E_OBSIDIAN_PATH=/Applications/Obsidian.app/Contents/MacOS/Obsidian
# OCTOSYNC_E2E_OBSIDIAN_CLI_PATH=/Applications/Obsidian.app/Contents/MacOS/obsidian-cli
# OCTOSYNC_E2E_KEEP_ARTIFACTS=false
# Refuse to run while a normal Obsidian instance is open on macOS.
# OCTOSYNC_E2E_ALLOW_EXISTING_OBSIDIAN=false
# Keep Obsidian, the throwaway vault, and the GitHub branch open when a run fails.
# OCTOSYNC_E2E_INSPECT_ON_FAILURE=false
# Print Obsidian stdout/stderr during launch and plugin loading.
# OCTOSYNC_E2E_VERBOSE=false
# OCTOSYNC_E2E_REMOTE_DEBUGGING_PORT=0
